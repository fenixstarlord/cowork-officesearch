# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Guild ID (optional, for faster slash command registration during dev)
DISCORD_GUILD_ID=

# Google Maps API Key (for maps, street view, geocoding, places)
GOOGLE_MAPS_API_KEY=

# Data directory (defaults to ../data/output)
DATA_DIR=
